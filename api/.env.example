# Zazz Board — API Environment Variables
# Copy this file to api/.env and keep the password aligned with your root .env

# Main database — must match the POSTGRES_PASSWORD in the root .env
DATABASE_URL=postgres://postgres:password@localhost:5433/zazz_board_db

# Test database (used only by automated tests — cleared on each run)
DATABASE_URL_TEST=postgres://postgres:password@localhost:5433/zazz_board_test

# Application
NODE_ENV=development
PORT=3030
LOG_LEVEL=info
