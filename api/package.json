{
  "name": "zazz-board",
  "version": "0.1.0",
  "description": "A Kanban style orchestration app intended to coordinate AI agents with users executing on a project.",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "dev:client": "vite",
    "build:client": "vite build",
    "preview:client": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push --yes",
    "db:seed": "node scripts/seed-all.js",
    "db:reset": "node scripts/reset-and-seed.js",
    "test": "NODE_ENV=test vitest run",
    "test:watch": "NODE_ENV=test vitest",
    "test:coverage": "NODE_ENV=test vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zazzcode/zazz-board.git"
  },
  "keywords": [
    "agentic",
    "kanban"
  ],
  "author": "Michael Woytowitz",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/zazzcode/zazz-board/issues"
  },
  "homepage": "https://github.com/zazzcode/zazz-board#readme",
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.4.0",
    "fastify-plugin": "^5.0.1",
    "pino": "^9.7.0",
    "postgres": "^3.4.7",
    "zod": "^4.0.10"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@vitest/coverage-v8": "^4.0.15",
    "drizzle-kit": "^0.31.8",
    "pactum": "^3.8.0",
    "vitest": "^4.0.15"
  }
}
