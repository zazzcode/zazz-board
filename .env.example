# Zazz Board Environment Variables
# Copy this file to .env and configure as needed

# ===========================================
# DOCKER COMPOSE
# ===========================================

# Docker Compose project name (used for container prefixes)
COMPOSE_PROJECT_NAME=zazz-board

# ===========================================
# DATABASE
# ==========================================
# Database used by Dockerized Postgres
POSTGRES_DB=zazz_board_db
POSTGRES_USER=postgres

# Shared password used by Postgres and API container DB connection
POSTGRES_PASSWORD=password

# ===========================================
# SERVER
# ===========================================

# Server port
PORT=3030

# Node environment
NODE_ENV=development

# ===========================================
# LOGGING
# ===========================================

# Log level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info
